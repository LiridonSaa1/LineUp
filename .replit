modules = ["web", "bash", "nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd artifacts/api-server && NODE_ENV=production SERVE_STATIC=true node --enable-source-maps ./dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && BASE_PATH=/ pnpm --filter @workspace/web run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "8080"
NODE_ENV = "development"
TWILIO_VERIFY_SERVICE_SID = "VA424e26776a462af1c4cf94a60fdc4595"

[[ports]]
localPort = 5000
externalPort = 80
